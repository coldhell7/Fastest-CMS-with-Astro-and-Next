---
import type { CatalogProduct } from "../../data/catalog";
import { formatToman } from "../../data/catalog";

type Props = { product: CatalogProduct };

const { product } = Astro.props;
const href = `/products/${product.slug}`;

const productJson = JSON.stringify({
  slug: product.slug,
  name: product.name,
  image: product.image,
  priceToman: product.priceToman,
  originalPriceToman: product.originalPriceToman ?? null,
});
---

<article class="product-card">
  <a href={href} class="product-card__link">
    <div class="product-card__image-wrap">
      <img
        src={product.image}
        alt={product.imageAlt}
        width="800"
        height="800"
        loading="lazy"
        decoding="async"
        referrerpolicy="no-referrer-when-downgrade"
        class="product-card__img"
      />
      {product.featured ? <span class="product-card__badge--featured">ویژه</span> : null}
      {product.badge ? <span class="product-card__badge">{product.badge}</span> : null}
    </div>
    <div class="product-card__body">
      <h3 class="product-card__name">{product.name}</h3>
      <p class="product-card__summary">{product.summary}</p>
      <div class="product-card__footer">
        <span class="product-card__price">
          {product.originalPriceToman ? (
            <>
              <span style="text-decoration:line-through;color:var(--text-muted);font-size:var(--text-sm);font-weight:400;margin-inline-end:6px;">{formatToman(product.originalPriceToman)}</span>
              {formatToman(product.priceToman)}
            </>
          ) : formatToman(product.priceToman)}
        </span>
        <span class="product-card__rating">★ {product.rating} ({product.reviewCount})</span>
      </div>
    </div>
  </a>
  <button class="product-card__add" data-add-to-cart={productJson}>
    افزودن به سبد
  </button>
</article>

<script>
  import { addToCart } from "../../lib/cart";

  document.querySelectorAll("[data-add-to-cart]").forEach((btn) => {
    btn.addEventListener("click", () => {
      try {
        const product = JSON.parse(btn.getAttribute("data-add-to-cart")!);
        addToCart(product);
        window.location.href = "/cart";
      } catch {}
    });
  });
</script>

<style>
  .product-card {
    display: flex;
    flex-direction: column;
    border-radius: var(--radius-lg);
    border: 1px solid var(--border);
    background: var(--surface);
    overflow: hidden;
    transition: box-shadow var(--transition-base), transform var(--transition-base);
  }
  .product-card:hover {
    box-shadow: var(--shadow-2);
    transform: translateY(-2px);
  }
  .product-card__link {
    display: flex;
    flex-direction: column;
    text-decoration: none;
    color: inherit;
    flex: 1;
  }
  .product-card__image-wrap {
    position: relative;
    aspect-ratio: 1 / 1;
    background: var(--bg-muted);
    overflow: hidden;
  }
  .product-card__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  .product-card__badge--featured {
    position: absolute;
    top: 12px;
    inset-inline-start: 12px;
    background: #f59e0b;
    color: #1c1917;
    font-size: var(--text-xs);
    font-weight: 800;
    padding: 6px 10px;
    border-radius: 999px;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.15);
  }
  .product-card__badge {
    position: absolute;
    top: 12px;
    inset-inline-end: 12px;
    background: var(--accent);
    color: var(--accent-foreground);
    font-size: var(--text-xs);
    font-weight: 700;
    padding: 6px 10px;
    border-radius: 999px;
  }
  .product-card__body {
    padding: var(--space-4);
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    flex: 1;
  }
  .product-card__name {
    margin: 0;
    font-size: var(--text-base);
    font-weight: 700;
    line-height: 1.35;
  }
  .product-card__summary {
    margin: 0;
    color: var(--text-muted);
    font-size: var(--text-sm);
    line-height: 1.5;
    flex: 1;
  }
  .product-card__footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-3);
    margin-top: auto;
  }
  .product-card__price {
    font-weight: 800;
    font-size: var(--text-lg);
  }
  .product-card__rating {
    font-size: var(--text-xs);
    color: var(--text-muted);
  }
  .product-card__add {
    width: 100%;
    border: none;
    padding: 12px;
    font: inherit;
    font-weight: 800;
    font-size: var(--text-sm);
    background: var(--accent);
    color: var(--accent-foreground);
    cursor: pointer;
    transition: opacity var(--transition-fast);
  }
  .product-card__add:hover { opacity: 0.9; }
</style>
